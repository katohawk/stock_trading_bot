# OKX API（复制此文件为 .env 并填入真实值，.env 已被 git 忽略）
# 创建 API 时 OKX 会给你：API Key、Secret Key；Passphrase 是你自己设的密码
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# 可选：币安
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# 监控推送（run_monitor.py --push，任选一个。交易需手动）
# 企业微信：群机器人 Webhook
# WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# 钉钉：群机器人 Webhook
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# 飞书：群机器人 Webhook
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# Server酱 / Bark / 自定义
# SERVERCHAN_SENDKEY=
# BARK_DEVICE_KEY=
# PUSH_WEBHOOK_URL=
